{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",              // ✅ FIX
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],            // ✅ fixes `process`
    "resolveJsonModule": true
  },

  "include": [
    "src",
    "prisma"
  ]
}
